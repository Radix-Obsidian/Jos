# Jos Sales Automation - Environment Variables
# Copy this file to .env and fill in your actual API keys

# Claude API (Required)
CLAUDE_API_KEY=sk-ant-oat01-

# X/Twitter API (Required for X monitoring)
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret

# Gmail API (Required for email outreach)
GMAIL_API_KEY=your_gmail_api_key
GMAIL_SENDER=your_email@gmail.com

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your_gateway_token

# Brave Search API (Optional, for web search)
BRAVE_API_KEY=your_brave_api_key

# Platform-specific settings
# Set to 'windows' or 'mac'
PLATFORM=windows

# Database
DATABASE_URL=sqlite:///./jos_db.sqlite

# Dashboard
DASHBOARD_PORT=5000
DASHBOARD_HOST=127.0.0.1

# Scheduler
SCHEDULER_TIMEZONE=US/Eastern

# Logging
LOG_LEVEL=DEBUG

# Feature flags
ENABLE_X_MONITORING=true
ENABLE_EMAIL_OUTREACH=true
ENABLE_FOLLOW_UP_AUTOMATION=true
ENABLE_LEAD_SCORING=true
ENABLE_DASHBOARD=true
ENABLE_PEEKABOO=false
ENABLE_THINGS=false
ENABLE_IMSG=false
